# Beehiiv API — get your key from https://app.beehiiv.com (Settings > API)
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=

# Content source — "markdown" (default), "ghost", or "hybrid"
CONTENT_SOURCE=markdown

# Ghost CMS — required when CONTENT_SOURCE is "ghost" or "hybrid"
# Get your Content API key from Ghost Admin > Settings > Integrations
GHOST_URL=
GHOST_CONTENT_API_KEY=